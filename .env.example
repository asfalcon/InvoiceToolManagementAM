# ============================================================
#  S&A - Financial Management — Configuracion local
# ============================================================
#
#  PASOS PARA EJECUTAR EN WINDOWS:
#
#  1. Instala PostgreSQL:
#       https://www.postgresql.org/download/windows/
#
#  2. Crea la base de datos (en la consola de PostgreSQL):
#       psql -U postgres -c "CREATE DATABASE sa_finanzas;"
#
#  3. Copia este archivo y llamalo ".env":
#       copy .env.example .env
#
#  4. Edita .env con tus datos de conexion (usuario, contrasena, etc.)
#
#  5. Crea las tablas (solo la primera vez):
#       npm run db:push
#
#  6. Ejecuta la aplicacion:
#       npm run dev
#     o simplemente haz doble clic en run-project.bat
#
# ============================================================

# Cadena de conexion a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=postgresql://postgres:TU_CONTRASENA@localhost:5432/sa_finanzas

# Clave secreta para sesiones (pon cualquier texto largo y aleatorio)
SESSION_SECRET=cambia-esto-por-una-clave-secreta-muy-larga
